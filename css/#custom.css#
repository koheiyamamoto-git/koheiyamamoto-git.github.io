body {
  background-color: #FFF2E6;
  margin: 0;
  font-family: sans-serif;
  letter-spacing: 0.05em;

  display: flex;
  justify-content: center;
}

/* 余計な指定は削除するのだ */
header, main, footer {
  padding: 20px 0;
}

/* 見出し */
h1, h2, h3 {
  font-weight: normal;
  margin-bottom: 40px;
}

/* 本文 */
p {
  line-height: 1.8;
  margin-bottom: 20px;
}

/* リンク */
a,
a:visited,
a:hover {
  color: #FF7800;
  text-decoration: none;
}

ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

li {
  margin-bottom: 10px;
}

/* 中央の本体 */
.wrapper {
  width: 100%;
  max-width: 600px;
  padding: 80px 20px;
  text-align: center;
}