body {
  background-color: #FFF2E6;
  margin: 0;
  font-family: sans-serif;
  letter-spacing: 0.05em;

  display: flex;
  justify-content: center; /* ← これが核心 */
}

/* ここが重要なのだ */
header, main, footer {
  max-width: 600px;
  margin: 0 auto;
  padding: 40px 20px;
  text-align: center;
}

/* 見出し */
h1, h2, h3 {
  font-weight: normal;
  margin-bottom: 40px;
}

/* 本文 */
p {
  line-height: 1.8;
  margin-bottom: 20px;
}

/* リンク */
a,
a:visited,
a:hover {
  color: #FF7800;
  text-decoration: none;
}

ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

li {
  margin-bottom: 10px;
}

.wrapper {
  width: 100%;
  max-width: 600px;
  padding: 80px 20px;
  text-align: center;
}
